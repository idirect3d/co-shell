#!/usr/bin/env python3
"""Deep-compare all cell values between original and modified xlsx."""
import zipfile, re, os, sys

os.chdir(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

orig_path = 'work/research/2026_calendar.xlsx'
mod_path = 'work/research/2026_calendar_auto_test_output.xlsx'

for p in [orig_path, mod_path]:
    if not os.path.exists(p):
        print(f"Error: {p} not found")
        sys.exit(1)

orig = zipfile.ZipFile(orig_path)
mod = zipfile.ZipFile(mod_path)

def get_cell_map(xml):
    rows = re.findall(r'<row[^>]*>(.*?)</row>', xml, re.DOTALL)
    result = {}
    for rxml in rows:
        rm = re.search(r'r="(\d+)"', rxml)
        if not rm: continue
        rn = int(rm.group(1))
        cells = re.findall(r'<c[^>]*?r="(\w+)"[^>]*>(.*?)</c>', rxml, re.DOTALL)
        for ref, body in cells:
            vm = re.search(r'<v>([^<]*)</v>', body)
            val = vm.group(1) if vm else ''
            result[(rn, ref)] = val
    return result

os_ = get_cell_map(orig.read('xl/worksheets/sheet1.xml').decode())
ms = get_cell_map(mod.read('xl/worksheets/sheet1.xml').decode())

print(f"Original cells: {len(os_)}, Modified cells: {len(ms)}")

# Check the specific rows
target_rows = set([3, 4, 12, 13, 21, 22, 30, 31])
missing_cols = {}
extra_cols = {}
val_diffs = []

for (rn, ref), val in sorted(os_.items()):
    if rn not in target_rows:
        continue
    nv = ms.get((rn, ref))
    if nv is None:
        missing_cols.setdefault(rn, []).append(ref)
    elif nv != val:
        val_diffs.append((rn, ref, val, nv))

for (rn, ref), val in sorted(ms.items()):
    if rn not in target_rows:
        continue
    if (rn, ref) not in os_:
        extra_cols.setdefault(rn, []).append(ref)

if missing_cols:
    for rn in sorted(missing_cols):
        print(f"❌ Row {rn}: missing cells: {', '.join(missing_cols[rn])}")
else:
    print(f"✅ No missing cells in target rows")

if extra_cols:
    for rn in sorted(extra_cols):
        print(f"⚠ Row {rn}: extra cells: {', '.join(extra_cols[rn])}")

if val_diffs:
    for rn, ref, ov, nv in val_diffs:
        print(f"❌ Row {rn} {ref}: value '{ov}' -> '{nv}'")
else:
    print("✅ All cell values match")

print()
print("Total differences found: value_diffs=%d, missing_cols=%s, extra_cols=%s" % (
    len(val_diffs),
    sum(len(v) for v in missing_cols.values()) if missing_cols else 0,
    sum(len(v) for v in extra_cols.values()) if extra_cols else 0
))